backend/datasets/vector_embeddings/*.jsonl filter=lfs diff=lfs merge=lfs -text
backend/datasets/knowledge_graph/*.jsonl filter=lfs diff=lfs merge=lfs -text

# Force LF regardless of platform -- a shell script checked out with CRLF
# (e.g. from a Windows core.autocrlf setting) breaks its own shebang line
# when run inside a Linux container, which is exactly where this runs.
*.sh text eol=lf
