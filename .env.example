ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proxy

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Storage
STORAGE_BUCKET_DOCUMENTS=case-documents

# Vector store: jsonl (local dev) | qdrant (required in production)
VECTOR_STORE_BACKEND=jsonl
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=proxy

# Graph store: jsonl (local dev) | neo4j (required in production)
GRAPH_STORE_BACKEND=jsonl
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=proxy-password

REDIS_URL=redis://localhost:6379/0

# LLM provider: gemini | nvidia
LLM_PROVIDER=gemini
# Generic override: forces every purpose model for whichever provider is active
# (reasoning/router/planner/response/summarization/ocr/kg_extraction). Leave
# blank to use the provider's per-purpose defaults below. For NVIDIA free-tier
# reliability, keep this on the 8B model — see PRIMARY GOAL note below.
LLM_MODEL=
LLM_FALLBACK_MODEL=meta/llama-3.1-8b-instruct
EMBEDDING_MODEL=gemini-embedding-001

# Generic timeouts/retries (apply to whichever provider is active)
MAX_RETRIES=2
TIMEOUT=25
EMBEDDING_TIMEOUT=15
HTTP_TIMEOUT=20
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
CACHE_ENABLED=true
CACHE_EMBEDDING_TTL_SECONDS=604800
CACHE_PROMPT_TTL_SECONDS=3600
CACHE_GRAPH_TTL_SECONDS=600
CACHE_CHUNKS_TTL_SECONDS=300

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
GEMINI_RESPONSE_MODEL=gemini-2.5-flash
GEMINI_SUMMARIZATION_MODEL=gemini-2.5-flash-lite
GEMINI_OCR_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_DIMENSION=768

# NVIDIA NIM (used when LLM_PROVIDER=nvidia)
# PRIMARY GOAL: optimize for free-tier reliability, not the largest models.
# Every purpose defaults to the fast 8B model. llama-3.3-70b / Qwen 80B /
# DeepSeek V4 are OPTIONAL — only set one of the per-purpose overrides below
# if you specifically want to try a bigger model for that purpose; ModelRouter
# will automatically fall back to LLM_FALLBACK_MODEL if it times out or
# returns 429/503, so trying a bigger model here is always safe to leave on.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_REASONING_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_RESPONSE_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_KG_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_RATE_LIMIT_PER_MINUTE=40
NVIDIA_EMBEDDING_DIMENSION=1024
# Vision model for document OCR (images + scanned PDF pages)
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct
OCR_MAX_PAGES=25
OCR_PAGE_CONCURRENCY=3
OCR_MAX_IMAGE_SIDE=1600
OCR_MAX_TOKENS=4096
OCR_TIMEOUT=90

# Auth
JWT_AUDIENCE=authenticated
JWT_ISSUER=

# Web search (Tavily)
TAVILY_API_KEY=
WEB_SEARCH_CACHE_TTL_SECONDS=86400
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=10

RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_MB=10
RESPONSE_AGENT_LLM_ENABLED=false
DISABLE_EXTERNAL_LLM=false

