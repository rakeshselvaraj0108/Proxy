ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proxy

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Storage
STORAGE_BUCKET_DOCUMENTS=case-documents

# Vector store: jsonl (local dev) | qdrant (required in production)
VECTOR_STORE_BACKEND=jsonl
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=proxy

# Graph store: jsonl (local dev) | neo4j (required in production)
GRAPH_STORE_BACKEND=jsonl
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=proxy-password

REDIS_URL=redis://localhost:6379/0

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
GEMINI_RESPONSE_MODEL=gemini-2.5-flash
GEMINI_SUMMARIZATION_MODEL=gemini-2.5-flash-lite
GEMINI_OCR_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# Auth
JWT_AUDIENCE=authenticated
JWT_ISSUER=

# Web search (Tavily)
TAVILY_API_KEY=
WEB_SEARCH_CACHE_TTL_SECONDS=86400
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=10

RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_MB=10
RESPONSE_AGENT_LLM_ENABLED=false
DISABLE_EXTERNAL_LLM=false
